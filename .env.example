# Copy to `.env.local` for local dashboard development.
# Production uses `.env.production` (see repo) or set BACKEND_ORIGIN on the host.

# --- Vercel (Project → Settings → Environment Variables) ---
# Set for Production (and Preview if you use the dashboard there):
#   BACKEND_ORIGIN   (defaults in .env.production; override per environment if needed)
#   ADMIN_API_KEY    (required for /api/backend proxy to admin routes — use Secret type)

# Backend Node API (scheme + host + port, no trailing slash).
BACKEND_ORIGIN=http://3.109.235.112:3040

# Required for admin dashboard routes (operators, analytics, bookings proxy).
# ADMIN_API_KEY=
